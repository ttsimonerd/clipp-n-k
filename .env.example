# ─────────────────────────────────────────────────────────────────────────────
# clipp'n'k — Docker self-hosting environment variables
#
# Copy this file to .env and fill in every value marked REQUIRED before
# running `docker compose up`.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────

# Password for the Postgres user created by the db container.
# Use a strong random value: openssl rand -hex 32
POSTGRES_PASSWORD=changeme   # REQUIRED

# ── App port ──────────────────────────────────────────────────────────────────

# Host port that nginx binds to. Change to 443 and add TLS termination if you
# are not putting this behind a reverse proxy (e.g. Coolify, Caddy, Traefik).
# Defaults to 80 when omitted.
PORT=80

# ── Sessions ──────────────────────────────────────────────────────────────────

# Secret used to sign session cookies. Must be long and random.
# Generate one with: openssl rand -hex 64
SESSION_SECRET=changeme   # REQUIRED

# ── Discord OAuth ─────────────────────────────────────────────────────────────
# 1. Go to https://discord.com/developers/applications and create an application.
# 2. Under OAuth2 → General, add a redirect URI:
#      https://<your-domain>/api/auth/discord/callback
# 3. Copy the Client ID and Client Secret below.

DISCORD_CLIENT_ID=    # REQUIRED
DISCORD_CLIENT_SECRET=    # REQUIRED

# Must exactly match the redirect URI you added in the Discord developer portal.
DISCORD_REDIRECT_URI=https://clips.example.com/api/auth/discord/callback   # REQUIRED

# ── Admin access ─────────────────────────────────────────────────────────────
# Comma-separated Discord user IDs (numeric) that receive admin access.
# Find your ID: Discord → Settings → Advanced → Enable Developer Mode, then
# right-click your username → Copy User ID.
ADMIN_DISCORD_IDS=123456789012345678   # REQUIRED

# ── Storage ───────────────────────────────────────────────────────────────────
# "local" stores clip files inside the container volume (default, zero config).
# "s3"    stores files in an S3-compatible bucket (AWS S3, MinIO, R2, etc.).
STORAGE_DRIVER=local

# ── S3-compatible storage (only when STORAGE_DRIVER=s3) ──────────────────────
S3_BUCKET=
S3_REGION=
# Custom endpoint for MinIO / Cloudflare R2 / other S3-compatible APIs.
# Leave blank for AWS S3.
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Set to "true" for MinIO path-style URLs; leave blank for AWS virtual-hosted.
S3_FORCE_PATH_STYLE=
# Public base URL for direct media delivery (e.g. https://pub.example.com).
# Leave blank to serve media through the API (proxied, auth-gated).
S3_PUBLIC_BASE_URL=

# ── GitHub OAuth — optional (star-bonus feature) ──────────────────────────────
# Users can link their GitHub account to earn +1 GB storage for starring the
# repo. Leave all three blank to disable the feature entirely.
#
# 1. Create an OAuth App at https://github.com/settings/developers
# 2. Set the callback URL to:
#      https://<your-domain>/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://clips.example.com/api/auth/github/callback
