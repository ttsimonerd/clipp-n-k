# ── Stage 1: Build the Vite SPA ──────────────────────────────────────────────
# Use Debian-based image to avoid musl/Alpine native-binary mismatches.
FROM node:24-bookworm-slim AS builder

WORKDIR /workspace

# Enable pnpm via corepack (matches the version used in development)
RUN corepack enable && corepack prepare pnpm@10.17.1 --activate

# Copy workspace manifests first for layer-cache efficiency.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY tsconfig.base.json tsconfig.json ./

# Copy every workspace package so pnpm can resolve workspace:* links.
COPY lib/ lib/
COPY artifacts/clippnk-web/ artifacts/clippnk-web/
COPY scripts/ scripts/

# Install deps (frozen lockfile for reproducible builds)
RUN pnpm config set only-built-dependencies esbuild
RUN pnpm install --frozen-lockfile

# Vite requires PORT at config-parse time
ENV PORT=3000
ENV BASE_PATH=/
ENV NODE_ENV=production

# Use LightningCSS WebAssembly fallback to avoid native binary issues in CI/ARM
ENV LIGHTNING_CSS_USE_WASM=1

# ─────────────────────────────────────────────────────────────────────────────
# ARM64 / native-binary fixes (best-effort, tolerant)
# - Install platform-specific rollup binary only on ARM64 (ignore failures)
# - Attempt to rebuild lightningcss native bindings (ignore failures)
# ─────────────────────────────────────────────────────────────────────────────
RUN if [ "$(uname -m)" = "aarch64" ]; then \
      pnpm add @rollup/rollup-linux-arm64-gnu lightningcss-linux-arm64-gnu @tailwindcss/oxide-linux-arm64-gnu --filter @workspace/clippnk-web || true; \
    fi

# Try to rebuild lightningcss native bindings for the current platform; if it fails,
# the earlier env forces the wasm fallback so the build still succeeds.
RUN pnpm rebuild lightningcss --filter @workspace/clippnk-web || true

# Build the SPA
RUN pnpm --filter @workspace/clippnk-web run build

# ── Stage 2: nginx static file server + reverse proxy ─────────────────────────
FROM nginx:1.27-alpine AS runtime

# Remove the default nginx site config.
RUN rm /etc/nginx/conf.d/default.conf

# Copy our site config (proxies /api and /c to the api container, serves SPA).
COPY nginx.conf /etc/nginx/conf.d/clippnk.conf

# Copy the Vite production build output.
COPY --from=builder /workspace/artifacts/clippnk-web/dist/public /usr/share/nginx/html

EXPOSE 80
